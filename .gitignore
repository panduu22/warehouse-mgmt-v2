# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
.env*.local

# vercel
.vercel

# typescript build artifacts
*.tsbuildinfo
next-env.d.ts

# one-time migration / debug scripts (should not be in repo)
/scripts/
/data/
/assets/
/icons/
generate_icon.py
lighthouse*.json
fix_*.ts
fix_*.js
migrate*.ts
migrate*.js
inspect*.js
patch_*.ts

# macOS system files
**/.DS_Store

